&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;		  &lt;span class=&#34;c1&#34;&gt;# wget https://archive.nuaa.cf/Xilinx/linux-xlnx/archive/refs/tags/xilinx-v2022.2.tar.gz&lt;/span&gt;
